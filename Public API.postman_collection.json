              "//     const savedPostcodes = pm.environment.get(\"search_postcodes\");",
              "//     pm.expect(savedPostcodes).to.not.be.undefined;",
              "//     pm.expect(savedPostcodes).to.be.a('string');",
              "//     pm.expect(JSON.parse(savedPostcodes)).to.be.an('array');",
              "// });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
