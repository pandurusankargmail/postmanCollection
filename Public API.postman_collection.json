      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the JSON response",
              "const jsonData = pm.response.json();",
              "",
              "// Test: Status code is 200",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test: 'results' exists and is non-empty",
              "pm.test(\"'results' exists and is non-empty\", function () {",
              "    pm.expect(jsonData).to.have.property('results');",
              "    pm.expect(jsonData.results).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "// Extract and save postcodes from the first result",
              "if (jsonData.results && jsonData.results.length > 0) {",
              "    const firstResult = jsonData.results[0];",
              "    ",
              "    // // Save the postcodes array as a JSON string",
              "    // if (firstResult.postcodes) {",
              "    //     pm.environment.set(\"search_postcodes\", JSON.stringify(firstResult.postcodes));",
              "        ",
              "        // Save the first postcode if present",
              "        if (firstResult.postcodes.length > 0) {",
              "            pm.environment.set(\"latitude\", firstResult.latitude);",
              "            pm.environment.set(\"longitude\", firstResult.longitude);",
              "            pm.environment.set(\"timezone\", firstResult.timezone);",
              "        }",
              "}",
              "",
              "",
              "// Test: 'postcodes' was saved to environment",
